<div class="container mx-auto p-6 max-w-4xl">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xl font-semibold">My Groups</h2>
    <%= link_to "Browse all groups", groups_path, class: "link link-hover text-sm" %>
  </div>

  <% if current_user.groups.empty? %>
    <div class="card bg-base-100 shadow">
      <div class="card-body text-center text-base-content/50">
        <p>You haven't joined any groups yet.</p>
        <div class="mt-2">
          <%= link_to "Browse groups", groups_path, class: "btn btn-primary btn-sm" %>
          <%= link_to "Create a group", new_group_path, class: "btn btn-ghost btn-sm" %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% current_user.groups.order(:name).each do |group| %>
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <h3 class="card-title text-base"><%= group.name %></h3>
            <% if group.description.present? %>
              <p class="text-base-content/70 text-sm line-clamp-2"><%= group.description %></p>
            <% end %>
            <div class="card-actions justify-end mt-1">
              <%= link_to "View", group, class: "btn btn-sm btn-primary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
