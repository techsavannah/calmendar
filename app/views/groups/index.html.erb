<% content_for :title, "Groups" %>

<div class="container mx-auto p-6 max-w-4xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-bold">Groups</h1>
    <%= link_to "New Group", new_group_path, class: "btn btn-primary" %>
  </div>

  <% if @groups.empty? %>
    <div class="text-center py-16 text-base-content/50">
      <p class="text-lg">No groups yet.</p>
      <p class="mt-2"><%= link_to "Create the first one", new_group_path, class: "link" %></p>
    </div>
  <% else %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% @groups.each do |group| %>
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <h2 class="card-title"><%= group.name %></h2>
            <% if group.description.present? %>
              <p class="text-base-content/70 text-sm line-clamp-2"><%= group.description %></p>
            <% end %>
            <p class="text-sm text-base-content/50">
              <%= pluralize(group.organizers.size, "organizer") %>
            </p>
            <div class="card-actions justify-end mt-2">
              <% if group.member?(current_user) %>
                <%= link_to "View", group, class: "btn btn-sm btn-primary" %>
              <% else %>
                <%= link_to "View", group, class: "btn btn-sm btn-ghost" %>
                <%= button_to "Join", group_group_memberships_path(group), method: :post, class: "btn btn-sm btn-primary" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
