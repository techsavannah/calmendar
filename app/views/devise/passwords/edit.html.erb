<div class="flex min-h-screen items-center justify-center">
  <div class="card w-full max-w-sm bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold">Set New Password</h2>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name),
            html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="form-control">
          <%= f.label :password, class: "label" do %>
            <span class="label-text">New Password</span>
            <% if @minimum_password_length %>
              <span class="label-text-alt"><%= @minimum_password_length %> characters minimum</span>
            <% end %>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-2">
          <%= f.label :password_confirmation, class: "label" do %>
            <span class="label-text">Confirm New Password</span>
          <% end %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-6">
          <%= f.submit "Change Password", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider text-xs">or</div>
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
